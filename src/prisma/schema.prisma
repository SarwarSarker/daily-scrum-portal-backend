generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             BigInt          @id @default(autoincrement())
  name           String?         @db.VarChar(120)
  email          String?         @unique @db.VarChar(120)
  password       String?         @db.VarChar(255)
  role           String?         @db.VarChar(20)
  designation    String?         @db.VarChar(100)
  avatar         String?
  teamId         BigInt?         @map("team_id")
  departmentId   BigInt?         @map("department_id")
  status         String?         @default("active") @db.VarChar(20)
  created_at     DateTime?       @default(now()) @db.Timestamp(6)
  updated_at     DateTime?       @default(now()) @db.Timestamp(6)
  projectUpdates ProjectUpdate[]
  taskComments   TaskComment[]
  ledTeams       Team[]          @relation("TeamLead")

  @@map("users")
}

model Project {
  id             BigInt          @id @default(autoincrement())
  status         String          @default("planning") @db.VarChar(20)
  description    String?
  blocker        String?         @db.VarChar(255)
  created_at     DateTime        @default(now()) @db.Timestamp(6)
  updated_at     DateTime        @default(now()) @db.Timestamp(6)
  name           String          @db.VarChar(255)
  owner_id       BigInt?
  team_id        BigInt?
  created_by     BigInt?
  projectUpdates ProjectUpdate[]
  tasks          Task[]

  @@map("projects")
}

model Task {
  id           BigInt        @id @default(autoincrement())
  project_id   BigInt
  assigned_to  BigInt?
  created_by   BigInt?
  title        String        @db.VarChar(255)
  description  String?
  priority     String        @default("medium") @db.VarChar(20)
  progress     Int?          @default(0)
  start_date   DateTime?     @db.Date
  end_date     DateTime?     @db.Date
  status       String        @default("todo") @db.VarChar(20)
  blocker      String?       @db.VarChar(255)
  output       String?       @db.Text
  created_at   DateTime      @default(now()) @db.Timestamp(6)
  updated_at   DateTime      @default(now()) @db.Timestamp(6)
  taskComments TaskComment[]
  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("tasks")
}

model ProjectUpdate {
  id                BigInt   @id @default(autoincrement())
  project_id        BigInt
  updated_by        BigInt
  update_date       DateTime @db.Date
  previous_progress Int?
  current_progress  Int?
  weekly_movement   Int?
  status            String?  @db.VarChar(100)
  today_update      String?
  blockers          String?
  next_action       String?
  timeline_note     String?
  remarks           String?
  created_at        DateTime @default(now()) @db.Timestamp(6)
  updated_at        DateTime @default(now()) @db.Timestamp(6)
  project           Project  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user              User     @relation(fields: [updated_by], references: [id], onUpdate: NoAction)

  @@map("project_updates")
}

model Department {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  teams      Team[]

  @@map("departments")
}

model TaskComment {
  id         BigInt   @id @default(autoincrement())
  task_id    BigInt
  user_id    BigInt
  comment    String
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("task_comments")
}

model Team {
  id            BigInt      @id @default(autoincrement())
  name          String      @db.VarChar(120)
  department_id BigInt?
  lead_id       BigInt?
  created_at    DateTime    @default(now()) @db.Timestamp(6)
  updated_at    DateTime    @default(now()) @db.Timestamp(6)
  department    Department? @relation(fields: [department_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lead          User?       @relation("TeamLead", fields: [lead_id], references: [id], onUpdate: NoAction)

  @@unique([department_id, name])
  @@map("teams")
}
