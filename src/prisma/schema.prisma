generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              BigInt            @id @default(autoincrement())
  name            String?           @db.VarChar(120)
  email           String?           @unique @db.VarChar(120)
  password        String?           @db.VarChar(255)
  role            String?           @db.VarChar(20)
  designation     String?           @db.VarChar(100)
  avatar          String?
  teamId          BigInt?           @map("team_id")
  departmentId    BigInt?           @map("department_id")
  status          String?           @default("active") @db.VarChar(20)
  createdAt       DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)
  attachments     attachments[]
  project_updates project_updates[]
  task_comments   task_comments[]
  teams           teams[]

  @@map("users")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model project_updates {
  id                BigInt        @id @default(autoincrement())
  project_id        BigInt
  updated_by        BigInt
  update_date       DateTime      @db.Date
  previous_progress Int?
  current_progress  Int?
  weekly_movement   Int?
  status            String?       @db.VarChar(100)
  today_update      String?
  blockers          String?
  next_action       String?
  timeline_note     String?
  remarks           String?
  created_at        DateTime      @default(now()) @db.Timestamp(6)
  updated_at        DateTime      @default(now()) @db.Timestamp(6)
  attachments       attachments[]
  projects          projects      @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             User          @relation(fields: [updated_by], references: [id], onUpdate: NoAction)
}

model projects {
  id              BigInt            @id @default(autoincrement())
  status          String            @default("planning") @db.VarChar(20)
  description     String?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime          @default(now()) @map("updated_at") @db.Timestamp(6)
  endDate         DateTime?         @map("end_date") @db.Date
  name            String            @db.VarChar(255)
  startDate       DateTime?         @map("start_date") @db.Date
  project_updates project_updates[]
  tasks           tasks[]

  @@map("projects")
}

model tasks {
  id            BigInt          @id @default(autoincrement())
  projectId     BigInt          @map("project_id")
  assignedTo    BigInt?         @map("assigned_to")
  title         String          @db.VarChar(255)
  description   String?
  status        String          @default("todo") @db.VarChar(20)
  priority      String          @default("medium") @db.VarChar(20)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime        @default(now()) @map("updated_at") @db.Timestamp(6)
  dueDate       DateTime?       @map("due_date") @db.Date
  attachments   attachments[]
  task_comments task_comments[]
  projects      projects        @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("tasks")
}

model attachments {
  id                BigInt           @id @default(autoincrement())
  task_id           BigInt?
  project_update_id BigInt?
  uploaded_by       BigInt?
  file_url          String
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @db.Timestamp(6)
  project_updates   project_updates? @relation(fields: [project_update_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks             tasks?           @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             User?            @relation(fields: [uploaded_by], references: [id], onUpdate: NoAction)
}

model departments {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  teams      teams[]
}

model task_comments {
  id         BigInt   @id @default(autoincrement())
  task_id    BigInt
  user_id    BigInt
  comment    String
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  tasks      tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model teams {
  id            BigInt       @id @default(autoincrement())
  name          String       @db.VarChar(120)
  department_id BigInt?
  lead_id       BigInt?
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)
  departments   departments? @relation(fields: [department_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         User?        @relation(fields: [lead_id], references: [id], onUpdate: NoAction)

  @@unique([department_id, name])
}
